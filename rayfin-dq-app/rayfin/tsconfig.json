{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "composite": true,
    "moduleResolution": "node16",
    "module": "node16",
    "noEmit": false,
    "allowImportingTsExtensions": false,
    "declaration": true,
    "outDir": ".temp/compiled",
    "experimentalDecorators": false,
    "emitDecoratorMetadata": false,
    "useDefineForClassFields": true
  },
  "include": ["data/**/*.ts"]
}
