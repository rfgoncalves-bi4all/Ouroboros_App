# Environment variables for rayfin-dq-app
#
# Copy this file to .env and fill in the values for your environment.
# All variables must be prefixed with VITE_ so that Vite exposes them
# to the browser bundle via import.meta.env.
#
# IMPORTANT: Never commit .env (with real values) to source control.

# ── Fabric SQL Analytics Endpoints ────────────────────────────────────────────
# The SQL Analytics Endpoint URL for the PROJECT Lakehouse
# (contains dq_quarantined, dq_flagged tables).
# Format: https://<workspace-id>.datawarehouse.fabric.microsoft.com
VITE_FABRIC_SQL_ENDPOINT_URL=

# The SQL Analytics Endpoint URL for the DQ ENGINE Lakehouse
# (contains dbo.dq_results).
# Format: https://<workspace-id>.datawarehouse.fabric.microsoft.com
VITE_DQ_ENGINE_SQL_ENDPOINT_URL=

# ── Schema names (match ouroboros-gx defaults) ────────────────────────────────
VITE_DQ_QUARANTINED_SCHEMA=dq_quarantined
VITE_DQ_FLAGGED_SCHEMA=dq_flagged

# ── Rayfin GraphQL endpoint (auto-injected at runtime by Rayfin SDK) ─────────
# Do not set this manually — Rayfin injects VITE_RAYFIN_GRAPHQL_URL at deploy time.
# VITE_RAYFIN_GRAPHQL_URL=
